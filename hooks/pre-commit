#!/bin/bash

echo "Running pre-commit checks..."

# Run lint
echo "Running lint..."
nice -n 19 pnpm lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Please fix the errors before committing."
  exit 1
fi

# Run type check
echo "Running type check..."
nice -n 19 pnpm tsc --noEmit
if [ $? -ne 0 ]; then
  echo "Type check failed. Please fix the errors before committing."
  exit 1
fi

# Run tests
echo "Running tests..."
NODE_OPTIONS="--max-old-space-size=2048" nice -n 19 npx vitest run --no-file-parallelism
if [ $? -ne 0 ]; then
  echo "Tests failed. Please fix the failing tests before committing."
  exit 1
fi

# Run build
echo "Running build..."
nice -n 19 pnpm build
if [ $? -ne 0 ]; then
  echo "Build failed. Please fix the build errors before committing."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
